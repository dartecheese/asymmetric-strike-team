# Copy this to .env and fill in your values

# Real Execution Mode (set to "true" to enable live transactions)
USE_REAL_EXECUTION=false

# Ethereum RPC endpoint (Infura, Alchemy, local node)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Private key of the wallet that will sign transactions (NEVER commit this!)
PRIVATE_KEY=0xYourPrivateKeyHere

# Optional: GoPlus API key for real-time honeypot detection
GOPLUS_API_KEY=your_goplus_api_key_here